# ==============================================================================
# VERSION AND UPDATE CONFIGURATION
# ==============================================================================

# SteamCMD game branch
# - "public" for the current stable version (Build 41)
# - "unstable" for the preview version of the new build (Build 42)
STEAMAPPBRANCH=public

# Force game update/download on container startup (True/False)
# Useful when changing branches (e.g. from public to unstable) to download new files.
FORCEUPDATE=False

# Use system-installed native ARM64 Java (openjdk-17-jre-headless) instead of the emulated JRE
# This will execute Java code natively on the ARM64 host, improving performance. (True/False)
USE_SYSTEM_JAVA=False

# ==============================================================================
# SECURITY AND ADMIN ACCESS
# ==============================================================================

# Username of the main administrator (default: admin)
ADMINUSERNAME=admin

# Administrator password (REQUIRED to be changed on first startup)
# IMPORTANT: It is recommended to clear/remove this after the first boot so the password is not exposed in cleartext in the logs.
ADMINPASSWORD=ChangeMePlease

# ==============================================================================
# GENERAL SERVER CONFIGURATION
# ==============================================================================

# Internal server name (defines config file names and save folder name)
# If left blank, defaults to "servertest". E.g.: SERVERNAME=MyServer
SERVERNAME=

# Language/Locale for the server console
LANG=en_EN.UTF-8

# Allow connections from non-official / non-Steam clients (True/False)
# Set to True to allow players with non-original game clients.
NOSTEAM=False

# Run the server in debug mode (True/False)
DEBUG=False

# Perform a soft reset on startup (clears dropped items and dead bodies) (True/False)
SOFTRESET=False

# ==============================================================================
# HARDWARE RESOURCES AND PERFORMANCE
# ==============================================================================

# Maximum RAM allocated to the server. Use "m" for Megabytes.
# Examples: 2048m (2GB), 4096m (4GB), 8192m (8GB), 16384m (16GB)
MEMORY=2048m

# Garbage Collector to use under emulation (default: UseSerialGC)
# SerialGC is single-threaded and avoids multithreaded GC race conditions/deadlocks under emulation.
# Alternative options: UseG1GC, UseZGC (but G1GC/ZGC are highly prone to crashes/hangs under Box64).
JVM_GC=UseSerialGC

# Limit JIT tiered compilation to a specific level (1-4). Leave blank to use JVM default (full C1+C2).
#   Level 1 = C1 only, no heavy optimizations (stable under Box64, good performance)
#   Level 2 = C1 with light profiling
#   Level 3 = C1 with full profiling
#   Level 4 = C2 full optimization (JVM default, may cause SIGSEGV crashes under Box64)
#   (empty) = JVM default, equivalent to level 4 (C1 + C2)
JVM_TIERED_STOP_AT_LEVEL=

# Run Java in interpreted mode (-Xint) to bypass ALL JIT compilation (True/False)
# WARNING: This is extremely slow and should only be used for debugging crashes.
# Use JVM_TIERED_STOP_AT_LEVEL=1 instead for a stable AND performant server under Box64.
JVM_INTERPRETED=False

# Enable fast NaN and fast Rounding in Box64 dynarec (True/False)
# This relaxes strict IEEE 754 compliance for a significant performance boost in math, physics, and pathfinding.
BOX64_FAST_MATH=True

# Box64 dynarec strong memory emulation level (0-3). Default: 1
# 1 is a good balance of speed and stability. Use 3 if you experience sporadic emulation crashes.
BOX64_STRONG_MEM=1

# Use eatmydata tool to disable fsync disk syncs (True/False)
# WARNING: Extremely useful for slow/mechanical hard drives (HDD) to eliminate save stutters
# and lag when driving. If True, database and map files write to memory and flush asynchronously.
# Risk: In case of OS crash or sudden power loss, the save data could be corrupted. Keep backups!
USE_EATMYDATA=False

# Custom directory for game cache files (saves, configuration, etc.)
# If left blank, uses steam user's home folder: /home/steam/Zomboid
CACHEDIR=

# Sandbox Preset to create a new game configuration from.
# E.g.: Survival, Apocalypse, or a custom preset name.
SERVERPRESET=

# ==============================================================================
# NETWORK AND PORTS
# ==============================================================================

# Server IP address to bind to (leave blank to listen on all interfaces)
IP=

# Main server port (default UDP: 16261)
PORT=16261

# Enable Valve Anti-Cheat (VAC) on the server (True/False)
STEAMVAC=True

# Steam query ports (optional, use if you need fixed query ports)
STEAMPORT1=
STEAMPORT2=

# ==============================================================================
# MOD CONFIGURATION (STEAM WORKSHOP)
# ==============================================================================

# Loading order of mod directories
MODFOLDERS=workshop,steam,mods

# Mod IDs separated by semicolons
# Example: ModId1;ModId2;ModId3
MOD_IDS=

# Steam Workshop IDs separated by semicolons
# Example: 2855152865;2856985474
WORKSHOP_IDS=